# Email/password test login (also shown automatically in `npm run dev`)
# Enable Email/Password in Firebase Console → Authentication first.
# VITE_ENABLE_TEST_LOGIN=true
# VITE_TEST_LOGIN_EMAIL=test@example.com
# VITE_TEST_LOGIN_PASSWORD=testpass123
