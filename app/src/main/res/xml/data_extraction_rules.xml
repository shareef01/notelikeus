<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="file" path="attachments/" />
        <exclude domain="file" path="datastore/settings.preferences_pb" />
        <exclude domain="sharedpref" path="db_security_prefs.xml" />
        <exclude domain="sharedpref" path="note_sync_state.xml" />
        <exclude domain="sharedpref" path="pending_cloud_sync.xml" />
        <exclude domain="file" path="db_passphrase.enc" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="." />
        <exclude domain="file" path="attachments/" />
        <exclude domain="file" path="datastore/settings.preferences_pb" />
        <exclude domain="sharedpref" path="db_security_prefs.xml" />
        <exclude domain="sharedpref" path="note_sync_state.xml" />
        <exclude domain="sharedpref" path="pending_cloud_sync.xml" />
        <exclude domain="file" path="db_passphrase.enc" />
    </device-transfer>
</data-extraction-rules>
